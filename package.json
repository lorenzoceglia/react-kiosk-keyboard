{
	"name": "@lorenzo.ceglia/react-kiosk-keyboard",
	"version": "0.1.1",
	"description": "A React kiosk keyboard component for touch screen applications.",
	"author": "Lorenzo Ceglia",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lorenzoceglia/react-kiosk-keyboard"
	},
	"homepage": "https://github.com/lorenzoceglia/react-kiosk-keyboard#readme",
	"bugs": {
		"url": "https://github.com/lorenzoceglia/react-kiosk-keyboard/issues"
	},
	"keywords": [
		"react",
		"kiosk",
		"keyboard",
		"virtual-keyboard",
		"touch-screen",
		"tailwind",
		"typescript",
		"component"
	],
	"main": "dist/index.cjs.js",
	"module": "dist/index.esm.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.esm.js",
			"require": "./dist/index.cjs.js",
			"types": "./dist/index.d.ts"
		},
		"./style": "./dist/index.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c",
		"dev": "rollup -c -w",
		"type-check": "tsc --noEmit",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"check": "biome check --write",
		"prepare": "husky"
	},
	"peerDependencies": {
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@rollup/plugin-node-resolve": "^15.0.0",
		"@rollup/plugin-terser": "^0.4.0",
		"@rollup/plugin-typescript": "^11.0.0",
		"@types/react": "^19.2.14",
		"husky": "^9.1.7",
		"postcss": "^8.4.0",
		"rollup": "^4.0.0",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"rollup-plugin-postcss": "^4.0.2",
		"tailwindcss": "^3.0.0",
		"tslib": "^2.6.0",
		"typescript": "^5.0.0"
	},
	"engines": {
		"node": ">=16.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
